# Authentication (client-side)
# The dashboard is protected by email-based authentication
# Only christopher.snook@veteranet.org is allowed access by default
# Configure in src/lib/auth.ts

# Public Feed URL - optional JSON endpoint for dynamic session data
NEXT_PUBLIC_PUBLIC_FEED_URL=

# Private Console URL - link to secure admin/console (Cloud Run with Google auth)
NEXT_PUBLIC_PRIVATE_CONSOLE_URL=

# For production deployment with Google Cloud Identity-Aware Proxy:
# Deploy to Cloud Run and enable IAP in Google Cloud Console
# This provides enterprise-grade authentication and access control
